<div class="wedding page-enter">

  <!-- Decoraciones esquinas -->
  <div class="page-corners" aria-hidden="true">
    <div class="corner-deco corner-deco--tl"></div>
    <div class="corner-deco corner-deco--tr"></div>
  </div>

  <!-- Header -->
  <header class="wedding__header">
    <div class="wedding__header-stars" aria-hidden="true">
      <span>✦</span><span>✦</span><span>✦</span>
    </div>
    <p class="wedding__date-label animate-in">12.12.2026</p>
    <h1 class="wedding__title animate-in animate-in-delay-1">La Boda</h1>
    <div class="ornament-divider animate-in animate-in-delay-2">
      <svg width="18" height="18" viewBox="0 0 18 18"><path d="M9 1l1.6 4.9H16l-4.1 3 1.6 4.9L9 10.8l-3.5 3 1.6-4.9L3 6l5.4-.1z" fill="#b5892a"/></svg>
    </div>
  </header>

  <!-- Contenido principal en dos columnas -->
  <div class="wedding__body container">
    <!-- Columna izquierda: texto descriptivo + ilustración -->
    <div class="wedding__left animate-in animate-in-delay-2">
      <div class="wedding__venue-card">
        <p class="wedding__venue-text">
          Todo sucederá en un lugar lleno de historia y encanto:
        </p>
        <h2 class="wedding__venue-name">La Casa de Mónico.</h2>

        <div class="heart-divider" aria-hidden="true"></div>

        <p class="wedding__venue-description">
          Un espacio único donde cada rincón invita a disfrutar,
          a brindar por lo que fuimos, por lo que somos
          y por todo lo que está por venir.
        </p>

        <div class="heart-divider" aria-hidden="true"></div>

        <p class="wedding__venue-description">
          Un día para vivirlo juntos, sin prisas,
          con el corazón lleno y rodeados de las personas
          que más queremos.
        </p>

        <!-- Sobre ilustrado -->
        <div class="wedding__envelope" aria-hidden="true">
          <svg viewBox="0 0 120 90" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="2" y="8" width="116" height="76" fill="#ede0cc" rx="4" stroke="#b5892a" stroke-width="1.5"/>
            <path d="M2 8 L60 52 L118 8" stroke="#b5892a" stroke-width="1.5" fill="none"/>
            <path d="M2 84 L40 50" stroke="#b5892a" stroke-width="1" opacity="0.4"/>
            <path d="M118 84 L80 50" stroke="#b5892a" stroke-width="1" opacity="0.4"/>
            <!-- Lacre -->
            <circle cx="60" cy="60" r="14" fill="#6b1f1f"/>
            <circle cx="60" cy="60" r="11" fill="#8b2c2c"/>
            <path d="M60 52 Q64 58 60 64 Q56 58 60 52" fill="#c0392b" opacity="0.6"/>
            <path d="M52 60 Q58 56 64 60 Q58 64 52 60" fill="#c0392b" opacity="0.6"/>
            <!-- Ramitas decorativas -->
            <path d="M2 4 Q10 0 18 4" stroke="#3d6040" stroke-width="2" fill="none"/>
            <circle cx="5" cy="2" r="3" fill="#8b2c2c"/>
            <path d="M118 4 Q110 0 102 4" stroke="#3d6040" stroke-width="2" fill="none"/>
            <circle cx="115" cy="2" r="3" fill="#8b2c2c"/>
          </svg>
        </div>
      </div>

      <!-- Ilustración del lugar (La Casa de Mónico) -->
      <div class="wedding__venue-illustration" aria-label="Ilustración de La Casa de Mónico">
        <svg viewBox="0 0 320 260" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Suelo nevado -->
          <rect x="0" y="230" width="320" height="30" fill="white" opacity="0.5"/>
          <ellipse cx="160" cy="232" rx="160" ry="10" fill="white" opacity="0.4"/>

          <!-- Edificio principal -->
          <rect x="40" y="80" width="240" height="160" fill="#ddd0b8"/>
          <rect x="40" y="80" width="240" height="12" fill="#c8b89a"/>

          <!-- Ala izquierda -->
          <rect x="10" y="110" width="50" height="130" fill="#d0c4aa"/>
          <rect x="10" y="108" width="50" height="8" fill="#c0b498"/>

          <!-- Ala derecha -->
          <rect x="260" y="110" width="50" height="130" fill="#d0c4aa"/>
          <rect x="260" y="108" width="50" height="8" fill="#c0b498"/>

          <!-- Tejado central -->
          <path d="M35 80 Q160 40 285 80" fill="#c0b498"/>
          <path d="M35 80 L40 80" stroke="#b0a488" stroke-width="1"/>
          <path d="M280 80 L285 80" stroke="#b0a488" stroke-width="1"/>

          <!-- Cúpula central -->
          <ellipse cx="160" cy="68" rx="28" ry="14" fill="#b8a888"/>
          <ellipse cx="160" cy="60" rx="16" ry="18" fill="#c8b89a"/>
          <rect x="156" y="38" width="8" height="24" fill="#b8a888"/>
          <path d="M144 60 Q160 42 176 60" fill="#a89878"/>
          <!-- Cruz en cúpula -->
          <line x1="160" y1="35" x2="160" y2="42" stroke="#9a7040" stroke-width="2"/>
          <line x1="156" y1="37" x2="164" y2="37" stroke="#9a7040" stroke-width="1.5"/>

          <!-- Ventanas principales -->
          <rect x="60" y="100" width="22" height="32" fill="#e8d5a0" rx="2" opacity="0.9"/>
          <rect x="94" y="100" width="22" height="32" fill="#e8d5a0" rx="2" opacity="0.9"/>
          <rect x="128" y="100" width="22" height="32" fill="#e8d5a0" rx="2" opacity="0.9"/>
          <rect x="172" y="100" width="22" height="32" fill="#e8d5a0" rx="2" opacity="0.9"/>
          <rect x="206" y="100" width="22" height="32" fill="#e8d5a0" rx="2" opacity="0.9"/>
          <rect x="240" y="100" width="22" height="32" fill="#e8d5a0" rx="2" opacity="0.9"/>

          <!-- Arcos ventanas superiores -->
          <path d="M60 100 Q71 96 82 100" fill="#c8b89a"/>
          <path d="M94 100 Q105 96 116 100" fill="#c8b89a"/>
          <path d="M128 100 Q139 96 150 100" fill="#c8b89a"/>
          <path d="M172 100 Q183 96 194 100" fill="#c8b89a"/>
          <path d="M206 100 Q217 96 228 100" fill="#c8b89a"/>
          <path d="M240 100 Q251 96 262 100" fill="#c8b89a"/>

          <!-- Ventanas planta baja -->
          <rect x="60" y="148" width="22" height="28" fill="#e8d5a0" rx="1" opacity="0.8"/>
          <rect x="100" y="148" width="22" height="28" fill="#e8d5a0" rx="1" opacity="0.8"/>
          <rect x="200" y="148" width="22" height="28" fill="#e8d5a0" rx="1" opacity="0.8"/>
          <rect x="240" y="148" width="22" height="28" fill="#e8d5a0" rx="1" opacity="0.8"/>

          <!-- Puerta principal -->
          <rect x="142" y="160" width="36" height="80" fill="#9a7040" rx="3"/>
          <path d="M142 160 Q160 150 178 160" fill="#7a5530"/>
          <rect x="148" y="168" width="10" height="16" fill="#e8d5a0" rx="1" opacity="0.8"/>
          <rect x="162" y="168" width="10" height="16" fill="#e8d5a0" rx="1" opacity="0.8"/>
          <circle cx="158" cy="202" r="2.5" fill="#d4a843"/>
          <circle cx="164" cy="202" r="2.5" fill="#d4a843"/>

          <!-- Árboles navideños laterales -->
          <g transform="translate(12,130)">
            <polygon points="18,0 30,22 20,22" fill="#2d4a2d"/>
            <polygon points="18,12 32,38 22,38 14,38 4,38" fill="#2d4a2d"/>
            <polygon points="18,25 35,55 20,55 16,55 1,55" fill="#2d4a2d"/>
            <rect x="14" y="55" width="8" height="10" fill="#9a7040"/>
            <circle cx="18" cy="5" r="2" fill="#d4a843"/>
            <circle cx="10" cy="24" r="2" fill="#c0392b"/>
            <circle cx="28" cy="22" r="1.5" fill="#e8c97a"/>
            <circle cx="6" cy="42" r="2" fill="#c0392b"/>
            <circle cx="30" cy="46" r="1.5" fill="#e8c97a"/>
          </g>

          <g transform="translate(268,130)">
            <polygon points="18,0 30,22 20,22" fill="#2d4a2d"/>
            <polygon points="18,12 32,38 22,38 14,38 4,38" fill="#2d4a2d"/>
            <polygon points="18,25 35,55 20,55 16,55 1,55" fill="#2d4a2d"/>
            <rect x="14" y="55" width="8" height="10" fill="#9a7040"/>
            <circle cx="18" cy="5" r="2" fill="#d4a843"/>
            <circle cx="8" cy="24" r="2" fill="#c0392b"/>
            <circle cx="28" cy="22" r="1.5" fill="#e8c97a"/>
            <circle cx="4" cy="42" r="2" fill="#c0392b"/>
            <circle cx="32" cy="46" r="1.5" fill="#e8c97a"/>
          </g>

          <!-- Farolas con guirnaldas -->
          <rect x="95" y="190" width="3" height="50" fill="#6b5040"/>
          <ellipse cx="96" cy="188" rx="8" ry="4" fill="#9a7040"/>
          <circle cx="96" cy="185" r="3" fill="#e8c97a" opacity="0.8"/>

          <rect x="222" y="190" width="3" height="50" fill="#6b5040"/>
          <ellipse cx="223" cy="188" rx="8" ry="4" fill="#9a7040"/>
          <circle cx="223" cy="185" r="3" fill="#e8c97a" opacity="0.8"/>

          <!-- Guirnalda entre farolas y edificio -->
          <path d="M96 188 Q140 200 160 196 Q180 192 223 188" stroke="#d4a843" stroke-width="1" fill="none" stroke-dasharray="3 6" opacity="0.6"/>
          <circle cx="120" cy="196" r="2.5" fill="#c0392b" opacity="0.7"/>
          <circle cx="145" cy="198" r="2.5" fill="#e8c97a" opacity="0.7"/>
          <circle cx="175" cy="196" r="2.5" fill="#c0392b" opacity="0.7"/>
          <circle cx="200" cy="193" r="2.5" fill="#e8c97a" opacity="0.7"/>

          <!-- Nieve en tejado -->
          <path d="M35 80 Q100 76 160 78 Q220 80 285 78" stroke="white" stroke-width="4" fill="none" opacity="0.7"/>
          <path d="M10 108 Q35 104 60 106" stroke="white" stroke-width="3" fill="none" opacity="0.6"/>
          <path d="M260 108 Q285 104 310 106" stroke="white" stroke-width="3" fill="none" opacity="0.6"/>

          <!-- Copos de nieve -->
          <text x="30" y="55" fill="white" font-size="12" opacity="0.6">❄</text>
          <text x="270" y="50" fill="white" font-size="10" opacity="0.5">❄</text>
          <text x="150" y="30" fill="white" font-size="8" opacity="0.4">❄</text>
        </svg>
      </div>
    </div>

    <!-- Columna derecha: timeline de eventos -->
    <div class="wedding__timeline animate-in animate-in-delay-3">
      <div class="wedding__timeline-line" aria-hidden="true"></div>

      <div class="wedding__event" *ngFor="let event of data.events(); let i = index"
           [style.animation-delay]="(i * 0.15 + 0.3) + 's'">
        <!-- Dot en la línea -->
        <div class="wedding__event-dot" aria-hidden="true">
          <svg viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="12" stroke="#b5892a" stroke-width="1.5" fill="var(--cream)"/>
            <circle cx="14" cy="14" r="7" fill="#b5892a" opacity="0.2"/>
            <circle cx="14" cy="14" r="3" fill="#b5892a"/>
          </svg>
        </div>

        <!-- Ilustración circular del evento -->
        <div class="wedding__event-icon-circle" aria-hidden="true">
          <span class="wedding__event-emoji">{{ event.icon }}</span>
        </div>

        <!-- Info del evento -->
        <div class="wedding__event-content">
          <span class="wedding__event-time">{{ event.hora }}</span>
          <h3 class="wedding__event-title">{{ event.titulo }}</h3>
          <p class="wedding__event-desc">{{ event.descripcion }}</p>
          <div class="wedding__event-heart" aria-hidden="true">♥</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decoración inferior -->
  <div class="wedding__footer-deco" aria-hidden="true">
    <div class="ornament-divider">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M10 1l1.8 5.5H17l-4.6 3.3 1.8 5.5L10 12l-4.2 3.3 1.8-5.5L3 6.5h5.2z" fill="currentColor"/>
      </svg>
    </div>
    <p class="wedding__footer-note">La Casa de Mónico · Madrid</p>
  </div>
</div>
